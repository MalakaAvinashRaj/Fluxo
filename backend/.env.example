# ── Required ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_key_here

# ── Server ────────────────────────────────────────────────────────────────────
# In Docker (docker-compose) AGENT_HOST and AGENT_PORT are set via environment block.
# Override here only if running the backend directly (not via docker-compose).
AGENT_HOST=0.0.0.0
AGENT_PORT=8080

# ── LLM ──────────────────────────────────────────────────────────────────────
DEFAULT_MODEL=gpt-4o-mini
MAX_TOKENS=128000
TEMPERATURE=0.1

# ── Preview URL ───────────────────────────────────────────────────────────────
# Empty = relative URLs (/preview/session/) — correct for production behind Nginx.
# Set to http://localhost:8080 for local development without Docker.
PREVIEW_BASE_URL=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Optional ──────────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=
# SENTRY_DSN=
# SESSION_STORAGE_PATH=./sessions