# ── Server ────────────────────────────────────────────────────────────────────
AGENT_HOST=0.0.0.0
AGENT_PORT=8081

# ── LLM ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_key_here
DEFAULT_MODEL=gpt-4o-mini
MAX_TOKENS=128000
TEMPERATURE=0.7

# ── Memory ────────────────────────────────────────────────────────────────────
MAX_CONTEXT_SIZE=272000
MEMORY_CACHE_TTL=3600

# ── Tools ─────────────────────────────────────────────────────────────────────
TOOL_TIMEOUT=30
MAX_PARALLEL_TOOLS=10

# ── Error handling ────────────────────────────────────────────────────────────
RETRY_ATTEMPTS=3
RETRY_DELAY=1.0
CIRCUIT_BREAKER_THRESHOLD=5

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Monitoring ────────────────────────────────────────────────────────────────
ENABLE_METRICS=false
METRICS_PORT=8082

# ── Paths ─────────────────────────────────────────────────────────────────────
SESSION_STORAGE_PATH=./sessions
PREVIEW_BASE_URL=https://fluxo.avinashrajmalaka.in

# ── Docker ────────────────────────────────────────────────────────────────────
DOCKER_IMAGE=flutter-dev-server:amd64
DOCKER_PLATFORM=linux/amd64

# ── Webhook ───────────────────────────────────────────────────────────────────
GITHUB_WEBHOOK_SECRET=79592103ec37853e214f8a16d22b6e1a9d58138940b6b80d2417dcaa19d4ed34
